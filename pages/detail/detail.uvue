  width: 100%;
  min-height: 100vh;
  padding: 80rpx 32rpx 180rpx;
  box-sizing: border-box;
  position: relative;
  background: #f9f3eb;
}
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
