  width: 100%;
  min-height: 100vh;
  padding: 80rpx 32rpx 180rpx;
  box-sizing: border-box;
  position: relative;
  background: #f9f3eb;
}
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
.bg{
  width: 100%;
  height: 100%;
}
.info-card {
  width: 50%;
  margin: 40rpx auto 30rpx;
  background: #d90000;
  padding: 18rpx;
  overflow: hidden;
  position: relative;
  z-index: 1;
}
.avatar {
  width: 100%;
  height: 438rpx;
  display: block;
}
.info-text {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.info-line {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
  line-height: 1.4;
}
.form-card {
  width: 95%;
  margin: 20rpx auto;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}
.form-title {
  font-size: 36rpx;
  color: #d90000;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.form-tip {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}
.form-item {
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.item-label {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}
.star { color: #d90000; } 
.item-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}
.item-textarea {
  width: 100%;
  max-height: 210rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  resize: none;
}
.submit-btn {
  width: 100%;
  height: 90rpx;
  background: #d90000;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 32rpx;
  margin-top: 20rpx;
}
</style>