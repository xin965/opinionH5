<template>
  <view class="container">
    <view class="bg-decoration">
      <image class="bg" src="/static/bg.jpg" mode="aspectFill"></image>
    </view>

    <view class="info-card">
      <image :src="avatar" class="avatar" mode="aspectFill"></image>
      <view class="info-text">
        <text class="info-line">姓名: {{ name }}</text>
        <text class="info-line">职务: {{ job }}</text>
        <text class="info-line">电话: {{ phone }}</text>
      </view>
    </view>

    <view class="form-card">
      <view class="form-title">意见反馈</view>
      <view class="form-tip">请填写表单中的内容</view>

      <view class="form-item">
        <view class="item-label">姓名<text class="star">*</text></view>
        <input class="item-input" v-model="formData.name" placeholder="待填写" />
      </view>

      <view class="form-item">
        <view class="item-label">职位<text class="star">*</text></view>
        <input class="item-input" v-model="formData.position" placeholder="待填写" />
      </view>

      <view class="form-item">
        <view class="item-label">电话<text class="star">*</text></view>
        <input class="item-input" v-model="formData.phone" type="number" placeholder="请输入11位手机号" maxlength="11" />
      </view>

      <view class="form-item">
        <view class="item-label">意见信息<text class="star">*</text></view>
        <textarea class="item-textarea" v-model="formData.content" placeholder="待填写"></textarea>
      </view>

      <button class="submit-btn" @click="handleSubmit">提交</button>
    </view>
  </view>
</template>

<script>
export default {
  data() {
    return {
      name: "",
      avatar: "",
      job: "",
      phone: "",
      formData: {
        name: "",
        position: "",
        phone: "",
        content: ""
      }
    };
  },
  onLoad(options) {
    this.name = decodeURIComponent(options.name || "")
    this.avatar = decodeURIComponent(options.avatar || "")
    this.job = decodeURIComponent(options.job || "")
    this.phone = decodeURIComponent(options.phone || "")
  },
  methods: {
    handleSubmit() {
      const { name, position, phone, content } = this.formData

      if (!name || !position || !phone || !content) {
        uni.showToast({ title: "请填写完整信息", icon: "none" })
        return
      }

      const phoneReg = /^1[3-9]\d{9}$/
      if (!phoneReg.test(phone)) {
        uni.showToast({ title: "请输入11位有效手机号", icon: "none" })
        return
      }

      uni.request({
        url: "/api/submit",
        method: "POST",
        data: {
          targetName: this.name,
          name,
          position,
          phone,
          content
        },
        success: (res) => {
          if (res.data.success) {
            uni.showToast({ title: "提交成功！", icon: "success" })
            this.formData = { name: "", position: "", phone: "", content: "" }
          } else {
            uni.showToast({ title: "提交失败", icon: "none" })
          }
        },
        fail: () => {
          uni.showToast({ title: "提交失败", icon: "none" })
        }
      })
    }
  }
}
</script>

<style scoped>
